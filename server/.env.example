# Copy this file to `.env` to run locally right away.
# These defaults match the local dev setup in this repository.

DATABASE_URL=postgres://postgres:1234@127.0.0.1:5432/g08_dispute
PORT=4000
CLIENT_ORIGIN=http://localhost:5173
UPLOAD_DIR=uploads

# Auth (dev defaults). For production, replace JWT_SECRET with a strong random value.
JWT_SECRET=g08-local-dev-change-me-to-random-secret
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=10

# Dev only: trust x-user-id without JWT (insecure; do not enable in production)
ALLOW_HEADER_AUTH=false
